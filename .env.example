NODE_ENV=development
PORT=4000
API_PREFIX=api/v1
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/flymenu?schema=public"
JWT_SECRET="change-me-in-development"
JWT_EXPIRES_IN="1d"
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
UPLOADS_DIR=uploads
PUBLIC_UPLOADS_PATH=/uploads
EMAIL_FROM="FlyMenu <no-reply@flymenu.local>"

# SMTP Configuration — set SMTP_USER + SMTP_PASSWORD to enable real delivery.
# Leave blank to auto-use an Ethereal test account (preview link printed to logs).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

# Initial Super Admin Credentials
ADMIN_EMAIL=admin@flymenu.com
ADMIN_PASSWORD=Password123!
